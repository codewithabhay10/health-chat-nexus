# ─── Backend-1 (backendNode / Express) environment variables ───
# Copy this file to ".env" and fill in your own values.

# MongoDB connection string (Atlas or local).
# Example (Atlas):  mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/health_chat
MONGODB_URI=your_mongodb_connection_string_here

# Secret used to sign session cookies.
# Generate a strong one with:  node generate-secret.js
SESSION_SECRET=your_random_session_secret_here

# Port the API listens on (defaults to 5000 if omitted)
PORT=5000

# "development" or "production"
NODE_ENV=development

# Optional: CallMeBot API key for WhatsApp appointment notifications.
# Leave blank to disable WhatsApp messages. See https://www.callmebot.com/
CALLMEBOT_API_KEY=
