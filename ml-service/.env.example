# ─── Backend-2 (database / FastAPI + ML) environment variables ───
# Copy this file to ".env" and fill in your own values.
# NOTE: these keep the "VITE_" prefix because the same names are reused
# across the stack — they are read here via python-dotenv / os.getenv().

# MongoDB connection string (must point at the same cluster as backendNode).
# Database name used by the code is "health_chat".
VITE_MONGO_URI=your_mongodb_connection_string_here

# Google Gemini API key — used for the /gemini chat endpoint and prescription OCR.
# Get one at https://aistudio.google.com/app/apikey
VITE_GOOGLE_GENAI_API_KEY=your_gemini_api_key_here
